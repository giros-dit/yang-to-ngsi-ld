module srl_nokia-srv6 {
  yang-version 1.1;
  namespace "urn:nokia.com:srlinux:srv6:srv6";
  prefix srl_nokia-srv6;

  import srl_nokia-features {
    prefix srl_nokia-feat;
  }
  import srl_nokia-common {
    prefix srl_nokia-comm;
  }
  import srl_nokia-system {
    prefix srl_nokia-system;
  }
  import srl_nokia-srv6-types {
    prefix srl_nokia-srv6-types;
  }

  organization
    "Nokia";
  contact
    "Nokia SR Linux Support
     Web: <http://www.nokia.com>";
  description
    "This YANG file covers the non-protocol specific segment routing v6 enhancements to SRL";

  revision 2025-03-31 {
    description
      "SRLinux 25.3.1";
  }

  grouping srv6-system {
    container srv6 {
      presence "Enable the srv6 context";
      description
        "Enter the srv6 context to configure locators and other SRv6 functionalities";
      list source-address {
        key "ip-address";
        max-elements 8;
        description
          "List of sourcess addresses";
        leaf ip-address {
          type srl_nokia-comm:ipv6-address-unicast;
          description
            "Source address used in the SRv6 packet";
        }
      }
      leaf default-source-address  {
        type leafref {
          path "../source-address/ip-address";
        }
        mandatory true;
        description
          "Default source address";
      }
      container micro-segment {
        description
          "Enter the micro-segment context";
        leaf block-length {
          type uint8 {
            range "32";
          }
          default "32";
          description
            "Micro-SID block length";
        }
        leaf gib-size {
          type uint8 {
            range "4..60";
          }
          default "16";
          description
            "Maximum number of micro-segment locators network wide (x 1024)";
        }
        leaf sid-length {
          type uint8 {
            range "16";
          }
          default "16";
          description
            "Micro-SID length";
        }
        list block {
          key "block-name";
          max-elements 8;
          description
            "Enter the block list instance";
          leaf block-name {
            type srl_nokia-comm:name {
              pattern '[^@]*' {
                error-message "Micro-segment block name cannot contain @";
              }
              length "1..64" {
                error-message "Micro-segment block name cannot be longer than 64 characters";
              }
            }
            description
              "Micro-SID block name";
          }
          container prefix {
            description
              "Enter the prefix context";
            leaf ip-prefix {
              type srl_nokia-comm:ipv6-prefix-unicast;
              mandatory true;
              description
                "SRv6 micro-segment block prefix";
            }
          }
          container static-function {
            description
              "Enter the static-function context";
            leaf max-entries {
              type uint32 {
                range "1..1048575";
              }
              default "1";
              description
                "Maximum number of static micro-segment functions";
            }
          }
        } //list block
      } //container micro-segment
      list locator {
        key "locator-name";
        max-elements 16;
        description
          "Enter the locator list instance";
        leaf locator-name {
          type srl_nokia-comm:name {
            pattern '[^@]*' {
              error-message "Locator name cannot contain @";
            }
            length "1..64" {
              error-message "Locator name cannot be longer than 64 characters";
            }
          }
          description
            "SRv6 locator name";
        }
        must 'not (full-segment = true() and micro-segment = true())' {
            error-message "Full-segment and micro-segment cannot be configured togather";
        }
        must 'not (full-segment = false() and micro-segment = false())' {
            error-message "Must configured either full-segment or micro-segment";
        }
        container full-segment {
          presence "Enable full-segment for the locator";
          description
            "Enter the context to configure the full-segment locator";
          leaf block-length {
            type uint8 {
              range "0|64|96";
            }
            default "0";
            description
              "SRv6 locator block address length";
          }
          leaf function-length {
            type uint8 {
              range "16";
            }
            mandatory true;
            description
              "Function length";
          }
          leaf argument-length {
            if-feature "srl_nokia-feat:srv6-dt2";
            type uint8 {
              range "0|16";
            }
            default "0";
            description
              "Argument length";
          }
          leaf algorithm {
            type uint32 {
              range "0|128..255";
            }
            default "0";
            description
              "IGP flexible algorithm ID";
          }
          container prefix {
            description
              "Enter the prefix context";
            leaf ip-prefix {
              type srl_nokia-comm:ipv6-prefix-unicast;
              mandatory true;
              description
                "SRv6 locator prefix";
            }
          }
          container static-function {
            description
              "Enter the static-function context";
            leaf max-entries {
              type uint32 {
                range "1..1048575";
              }
              default "1";
              description
                "Maximum number of static SID functions";
            }
          }
        } //container full-segment
        container micro-segment {
          presence "Enable micro-segment for the locator";
          description
            "Enter the context to configure the micro-segment locator";
          leaf block {
            type leafref {
              path "../../../micro-segment/block/block-name";
            }
            mandatory true;
            description
              "Pre-defined micro-SID block";
          }
          leaf argument-length {
            if-feature "srl_nokia-feat:srv6-dt2";
            type uint8 {
              range "0|16";
            }
            default "0";
            description
              "Argument length";
          }
          leaf algorithm {
            type uint32 {
              range "0|128..255";
            }
            default "0";
            description
              "IGP flexible algorithm ID";
          }
          container un {
            description
              "Enter the un context";
            leaf srh-mode {
              type srl_nokia-srv6-types:srh-mode;
              default "psp";
              description
                "Segment Routing Header (SRH) mode";
            }
            leaf value {
              type uint32 {
                range "1..1048575";
              }
              mandatory true;
              description
                "SRv6 uN function value";
            }
          }
        } //container micro-segment
      } // list locator
    } // container srv6
  }

  augment "/srl_nokia-system:system" {
    uses srv6-system;
    if-feature "srl_nokia-feat:srv6";
  }
}
